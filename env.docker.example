# Copy to .env when running the Node bot inside the same Docker / Compose network
# as MongoDB, NapCat, and Qdrant.

LLM_API_KEY=replace-with-your-llm-api-key
OPENAI_API_KEY=replace-with-your-llm-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

NAPCAT_API=http://napcat:3001
NAPCAT_TOKEN=replace-with-your-napcat-token

# Docker service names are valid here because the app is expected to run
# inside the same Compose / container network.
MONGODB_URI=mongodb://mongo:27017/yuno

ADMIN_QQ=replace-with-your-admin-qq
TARGET_GROUP_ID=replace-with-your-target-group-id
SELF_QQ=replace-with-your-bot-qq
PORT=3000

# Optional voice output. Keep this off until ffmpeg and TTS are ready.
ENABLE_VOICE=false
FFMPEG_PATH=/usr/bin/ffmpeg
YUNO_VOICE_URI=replace-with-your-voice-uri
TTS_API_KEY=replace-with-your-tts-key
TTS_BASE_URL=replace-with-your-tts-base-url
TTS_MODEL=replace-with-your-tts-model

# Optional retrieval. After filling these, run npm run kb:sync once.
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=qq_bot_knowledge
QDRANT_API_KEY=

# Chat interaction tuning (optional)
CHAT_FOLLOWUP_RATE_PRIVATE=0.72
CHAT_FOLLOWUP_RATE_GROUP=0.24
CHAT_STYLE_REPEAT_GUARD=true
CHAT_ELLIPSIS_LIMIT=2

ENABLE_QUEUE=true
REDIS_URL=redis://redis:6379
