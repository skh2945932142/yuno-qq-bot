# Copy to .env when running the Node bot directly on a Linux server.
# Replace every placeholder before starting the app.

LLM_API_KEY=replace-with-your-llm-api-key
OPENAI_API_KEY=replace-with-your-llm-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# NapCat / OneBot bridge reachable from the server host
NAPCAT_API=http://127.0.0.1:3001
NAPCAT_TOKEN=replace-with-your-napcat-token

# Use a host-reachable MongoDB address here. Do not use docker-only service names
# unless Node is running in the same container network.
MONGODB_URI=mongodb://127.0.0.1:27017/yuno

ADMIN_QQ=replace-with-your-admin-qq
TARGET_GROUP_ID=replace-with-your-target-group-id
SELF_QQ=replace-with-your-bot-qq
PORT=3000

# Public endpoint protection. Configure NapCat or your reverse proxy to send
# x-yuno-webhook-secret with the same value.
ONEBOT_WEBHOOK_SECRET=replace-with-a-long-random-secret
WEBHOOK_BODY_LIMIT=128kb
METRICS_AUTH_TOKEN=replace-with-a-long-random-metrics-token

# Optional voice output. Keep this off until ffmpeg and TTS are ready.
ENABLE_VOICE=false
FFMPEG_PATH=/usr/bin/ffmpeg
YUNO_VOICE_URI=replace-with-your-voice-uri
TTS_API_KEY=replace-with-your-tts-key
TTS_BASE_URL=replace-with-your-tts-base-url
TTS_MODEL=replace-with-your-tts-model

# Optional retrieval. After filling these, run npm run kb:sync once.
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=qq_bot_knowledge
QDRANT_API_KEY=

# Chat interaction tuning (optional)
BOT_EXPERIENCE_MODE=companion
REQUEST_TIMEOUT_MS=60000
REPLY_HARD_TIMEOUT_MS=12000
EXTERNAL_TOOL_TIMEOUT_MS=4000
CHAT_FOLLOWUP_RATE_PRIVATE=0.72
CHAT_FOLLOWUP_RATE_GROUP=0.24
CHAT_STYLE_REPEAT_GUARD=true
CHAT_ELLIPSIS_LIMIT=2
MODEL_CIRCUIT_FAILURE_THRESHOLD=3
MODEL_CIRCUIT_OPEN_MS=20000
REPLY_TIME_BUDGET_MS=0
# Set REPLY_TIME_BUDGET_MS > 0 to re-enable short-reply budget fallback.
MODEL_FALLBACK_CHAT_MODEL=
KNOWLEDGE_QUERY_CACHE_TTL_MS=30000
GROUP_EVENT_RETENTION_COUNT=100
AUTOMATION_TASK_CONCURRENCY=3
MEMORY_EXTRACTION_ENABLED=true
MEMORY_SUMMARY_MODEL=
MEME_VISION_ENABLED=true

# Optional external enrichment providers
VISION_API_KEY=
VISION_BASE_URL=
VISION_MODEL=
OCR_API_KEY=
OCR_BASE_URL=
SEARCH_API_KEY=
SEARCH_BASE_URL=

# Optional queue / Redis
ENABLE_QUEUE=false
REDIS_URL=redis://127.0.0.1:6379
