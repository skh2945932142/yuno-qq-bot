# Copy to .env when running the Node bot directly on a Linux server.
# Replace every placeholder before starting the app.

LLM_API_KEY=replace-with-your-llm-api-key
OPENAI_API_KEY=replace-with-your-llm-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# NapCat / OneBot bridge reachable from the server host
NAPCAT_API=http://127.0.0.1:3001
NAPCAT_TOKEN=replace-with-your-napcat-token

# Use a host-reachable MongoDB address here. Do not use docker-only service names
# unless Node is running in the same container network.
MONGODB_URI=mongodb://127.0.0.1:27017/yuno

ADMIN_QQ=replace-with-your-admin-qq
TARGET_GROUP_ID=replace-with-your-target-group-id
SELF_QQ=replace-with-your-bot-qq
PORT=3000

# Optional voice output. Keep this off until ffmpeg and TTS are ready.
ENABLE_VOICE=false
FFMPEG_PATH=/usr/bin/ffmpeg
YUNO_VOICE_URI=replace-with-your-voice-uri
TTS_API_KEY=replace-with-your-tts-key
TTS_BASE_URL=replace-with-your-tts-base-url
TTS_MODEL=replace-with-your-tts-model

# Optional retrieval. After filling these, run npm run kb:sync once.
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=qq_bot_knowledge
QDRANT_API_KEY=

# Optional queue / Redis
ENABLE_QUEUE=false
REDIS_URL=redis://127.0.0.1:6379
