# Fill this file and rename it to .env before deployment.

# AstrBot container
ASTRBOT_IMAGE=replace-with-your-astrbot-image
ASTRBOT_PORT=6185
ASTRBOT_TIMEZONE=Asia/Shanghai

# OpenAI-compatible provider used by your Yuno deployment
OPENAI_API_KEY=replace-with-your-openai-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_CHAT_MODEL=gpt-4o-mini
EMBEDDING_API_KEY=replace-with-your-embedding-api-key
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# NapCat / OneBot bridge
NAPCAT_WS_URL=ws://napcat:3001
NAPCAT_HTTP_URL=http://napcat:3001
NAPCAT_TOKEN=replace-with-your-napcat-token
BOT_QQ=replace-with-your-bot-qq

# Yuno application
YUNO_PORT=3000
MONGODB_URI=mongodb://mongo:27017/yuno
ADMIN_QQ=replace-with-your-admin-qq
TARGET_GROUP_ID=replace-with-your-group-id
ONEBOT_WEBHOOK_SECRET=replace-with-a-long-random-secret
WEBHOOK_BODY_LIMIT=128kb
METRICS_AUTH_TOKEN=replace-with-a-long-random-metrics-token
ENABLE_VOICE=false

# Optional Yuno retrieval
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=qq_bot_knowledge
QDRANT_TOP_K=4
QDRANT_MIN_SCORE=0.25
QDRANT_CHAR_LIMIT=1200

# Optional meme and trigger controls
MEME_ENABLED=true
MEME_AUTO_COLLECT=true
MEME_AUTO_SEND=false
MEME_AUTO_SEND_MODE=suggest
MEME_AUTO_SEND_COOLDOWN_MS=300000
MEME_AUTO_SEND_MIN_SCORE=0.72
MEME_AUTO_SEND_MAX_PER_HOUR=3
MEME_ENABLED_GROUPS=["replace-with-your-group-id"]
